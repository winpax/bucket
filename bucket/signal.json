{
    "version": "8.4.0",
    "description": "A cross-platform encrypted messaging service.",
    "homepage": "https://signal.org",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://updates.signal.org/desktop/signal-desktop-win-8.4.0.exe#/dl.7z",
            "hash": "sha512:743a3a51ce8095bb8bf393f6c0b184c939498488fc481b55e3b51da9a57253505d1cac73dbf841123a2d0c35c0f9f89cb165e779ad0db261a755a14475695cf2",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*.exe\" -Recurse -Force"
            ]
        }
    },
    "bin": "signal.exe",
    "shortcuts": [
        [
            "signal.exe",
            "Signal"
        ]
    ],
    "checkver": {
        "url": "https://updates.signal.org/desktop/latest.yml",
        "regex": "version:\\s([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://updates.signal.org/desktop/signal-desktop-win-$version.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s$base64"
        }
    }
}
