{
    "version": "8.17.0",
    "description": "A cross-platform encrypted messaging service.",
    "homepage": "https://signal.org",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://updates.signal.org/desktop/signal-desktop-win-8.17.0.exe#/dl.7z",
            "hash": "sha512:b99280ea190a39f5af8e18f1aae9589d6eaac76e4b030b2bafc176af6bbbbd73db1b220e703b56234b7fb1c66be892a63f4f9d2b1593b0b0c09c621306f7182e",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*.exe\" -Recurse -Force"
            ]
        }
    },
    "bin": "signal.exe",
    "shortcuts": [
        [
            "signal.exe",
            "Signal"
        ]
    ],
    "checkver": {
